{
  "buildCommand": "pnpm --filter @workspace/il-ambiental-site run build",
  "outputDirectory": "artifacts/il-ambiental-site/dist/public",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "functions": {
    "api/contact.ts": {
      "memory": 256,
      "maxDuration": 15
    }
  },
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
